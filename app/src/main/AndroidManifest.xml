<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="mx.unam.fc.icat.funz">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FunZ"
        android:name=".data.FunZApp">

        <!-- Pantalla A: Inicio (MAIN) -->
        <activity android:name=".ui.main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Pantalla B: Temas -->
        <activity android:name=".ui.temas.TemasActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla C: Info / Ejemplos -->
        <activity android:name=".ui.temas.InfoEjemplosActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla D1: Ejercicio Balanza -->
        <activity android:name=".ui.ejercicios.EjercicioBalanzaActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla D2: Ejercicio Clásico -->
        <activity android:name=".ui.ejercicios.EjercicioClasicoActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla D3: Ejercicio Algebra Tiles -->
        <activity android:name=".ui.ejercicios.EjercicioTilesActivity"
            android:screenOrientation="portrait"/>

        <!-- Fin ejercicios -->
        <activity android:name=".ui.ejercicios.FinEjerciciosActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla E: Salas -->
        <activity android:name=".ui.sala.SalasActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla M: Estadísticas -->
        <activity android:name=".ui.stats.EstadisticasActivity"
            android:screenOrientation="portrait"/>

        <!-- Pantalla N: Configuración -->
        <activity android:name=".ui.config.ConfiguracionActivity"
            android:screenOrientation="portrait"/>

    </application>
</manifest>
