<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_tile_positive.xml
    Drawable con estados para tiles de números positivos (+1, +2, …).
    - Presionado → azul oscuro
    - Normal     → azul medio
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/tile_positive_pressed"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/tile_positive"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
</selector>

