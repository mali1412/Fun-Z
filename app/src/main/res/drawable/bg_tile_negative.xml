<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_tile_negative.xml
    Drawable con estados para tiles de números negativos (-1, -2, …).
    - Presionado → rojo oscuro
    - Normal     → rojo error
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/tile_negative_pressed"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/tile_negative"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
</selector>

