<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Pantalla A: Inicio
    Hero gradient morado + grid 2x2 de acceso rápido.
    Sin BottomNavigationView (solo aparece en Temas, Stats y Config).
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Avatar:  -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_person"
                    android:padding="8dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#161;Hola, Marco!"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128293; Racha: 7 d&#237;as"
                        android:textColor="#E0BBFF"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Medallas -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="&#129353;" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="&#128293;" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="&#127885;" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle_locked" android:alpha="0.5"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CONTINUAR CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTINUAR"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_resume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:strokeColor="@color/color_primary"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/tv_resume_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M&#243;dulo 1 · Ej. 1/3"
                            android:textSize="10sp"
                            app:chipBackgroundColor="@color/color_primary_alpha"
                            android:textColor="@color/color_primary_dark"/>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tv_resume_method"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Balanza"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_resume_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ecuaciones lineales"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tv_resume_eq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="x + 5 = 10"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp"/>

                    <ProgressBar
                        android:id="@+id/pb_resume"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_bar_purple"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_resume"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_gravity="end"
                        android:text="&#9654; Reanudar"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/color_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACCESO RÁPIDO 2x2 GRID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCESO R&#193;PIDO"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- Temas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_temas"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_rowWeight="1"
                    android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#128218;" android:textSize="26sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Temas" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Salas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_salas"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_rowWeight="1"
                    android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#127999;" android:textSize="26sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Salas" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Estadísticas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_stats"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_rowWeight="1"
                    android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#128202;" android:textSize="26sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Estad&#237;sticas" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Configuración -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_config"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_rowWeight="1"
                    android:layout_margin="4dp" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="&#9881;&#65039;" android:textSize="26sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Configuraci&#243;n" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>
        </LinearLayout>
    </LinearLayout>

</ScrollView>
