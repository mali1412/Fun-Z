<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient"
            android:orientation="vertical"
            android:padding="@dimen/margin_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_small">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="@dimen/inlay_action_button_size"
                    android:layout_height="@dimen/inlay_action_button_size"
                    android:src="@drawable/ic_person"
                    android:padding="@dimen/margin_small"
                    android:background="@drawable/bg_avatar_circle"
                    android:layout_marginEnd="@dimen/padding_card"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_base"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_h2"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/streak_default"
                        android:textColor="#E0BBFF"
                        android:textSize="@dimen/text_size_small"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="@string/medal_bronze" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle" android:layout_marginEnd="@dimen/margin_small"/>
                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="@string/medal_fire" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle" android:layout_marginEnd="@dimen/margin_small"/>
                <TextView android:layout_width="36dp" android:layout_height="36dp"
                    android:text="@string/medal_grad" android:textSize="20sp" android:gravity="center"
                    android:background="@drawable/bg_medal_circle_locked" android:alpha="0.5"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_default">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_continue"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_resume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/margin_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/tv_resume_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modulo"
                            android:textSize="@dimen/text_size_small"
                            app:chipBackgroundColor="@color/color_primary_alpha"
                            android:textColor="@color/color_primary_dark"/>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tv_resume_method"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_practice"
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_resume_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loading"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <ProgressBar
                        android:id="@+id/pb_resume"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/progress_bar_height"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_bar_purple"
                        android:layout_marginTop="@dimen/margin_small"
                        android:layout_marginBottom="@dimen/margin_small"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_resume"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height"
                        android:layout_gravity="end"
                        android:text="@string/btn_resume"
                        android:textSize="@dimen/text_size_small"
                        app:cornerRadius="@dimen/margin_small"
                        android:backgroundTint="@color/color_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_quick_access"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <!-- Temas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_temas"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="@dimen/margin_small"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/color_bg_tonal_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/qa_temas"
                            android:src="@drawable/ic_book" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/qa_temas"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/margin_small"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Salas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_salas"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="@dimen/margin_small"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/color_bg_tonal_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/qa_salas"
                            android:src="@drawable/ic_room" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/qa_salas"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/margin_small"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_stats"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="@dimen/margin_small"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/color_bg_tonal_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/qa_stats"
                            android:src="@drawable/ic_bar_chart" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/qa_stats"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/margin_small"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Config -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/qa_config"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="@dimen/margin_small"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/color_bg_tonal_card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@string/qa_config"
                            android:src="@drawable/ic_settings" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/qa_config"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/margin_small"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>