<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOOLBAR SUPERIOR -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_tiny"
        android:paddingEnd="@dimen/margin_tiny"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/card_elevation">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/btn_exit_text"
            android:textSize="@dimen/text_size_tiny"
            android:textColor="?attr/colorPrimary"
            app:cornerRadius="@dimen/margin_small"
            tools:ignore="SmallSp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/exercise_title_1"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/timer_default"
            android:textSize="@dimen/text_size_tiny"
            android:fontFamily="monospace"
            app:chipBackgroundColor="?attr/colorWarnChipBg"
            android:textColor="?attr/colorWarnChipText"
            android:layout_marginEnd="@dimen/margin_tiny"
            tools:ignore="SmallSp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hint"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/medal_icon_size"
            android:layout_height="@dimen/medal_icon_size"
            android:text="@string/btn_hint"
            android:textSize="@dimen/text_size_small"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"
            android:layout_marginEnd="@dimen/margin_tiny"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/medal_icon_size"
            android:layout_height="@dimen/medal_icon_size"
            android:text="@string/btn_hamburger"
            android:textSize="@dimen/text_size_body"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"/>
    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/toolbar_height"
        android:padding="@dimen/margin_small">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/method_balanza"
                android:textSize="@dimen/text_size_tiny"
                app:chipBackgroundColor="?attr/colorPrimaryAlpha"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="@dimen/margin_small"
                tools:ignore="SmallSp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/padding_card"
                app:cardElevation="0dp"
                android:layout_marginBottom="@dimen/padding_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_default">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_solve" android:textSize="@dimen/text_size_tiny" android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/margin_tiny"
                        tools:ignore="SmallSp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/eq_balanza"
                        android:textSize="@dimen/text_size_equation" android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Contenedor de la balanza -->
            <RelativeLayout
                android:id="@+id/container_balanza"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="20dp">

                <!-- Base de la balanza (estática) -->
                <ImageView
                    android:id="@+id/balanza_base"
                    android:layout_width="15dp"
                    android:layout_height="150dp"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:src="@drawable/ic_balanza_base" />

                <!-- Brazo de la balanza (el que va a rotar) -->
                <!-- PivotX y PivotY al 50% para que gire sobre su propio centro -->
                <ImageView
                    android:id="@+id/balanza_brazo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_above="@id/balanza_base"
                    android:layout_marginBottom="-40dp"
                    android:src="@drawable/ic_balanza_brazo_con_platos"
                    android:transformPivotX="150dp"
                    android:transformPivotY="20dp" />
                <!-- Nota: Ajusta los pivots o usa pivotX/Y en código para precisión -->

            </RelativeLayout>

            <!-- Texto de la ecuación -->
            <TextView
                android:id="@+id/tv_ecuacion_visual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="x + 3 = 10"
                android:textSize="24sp"
                android:layout_gravity="center" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginBottom="@dimen/margin_small"
                android:baselineAligned="false">
                <TextView android:id="@+id/tv_lhs" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="@dimen/text_size_small"
                    android:fontFamily="monospace" android:textColor="?attr/colorPrimary"
                    android:gravity="center" android:background="@drawable/bg_chip_outlined"
                    android:padding="@dimen/margin_small" android:layout_marginEnd="@dimen/margin_tiny"
                    tools:text="x+5" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equal_sign" android:textSize="@dimen/text_size_body" android:textColor="?attr/colorTextSecondary"
                    android:layout_marginHorizontal="@dimen/margin_tiny"/>
                <TextView android:id="@+id/tv_rhs" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="@dimen/text_size_small"
                    android:fontFamily="monospace" android:textColor="?attr/colorPrimary"
                    android:gravity="center" android:background="@drawable/bg_chip_outlined"
                    android:padding="@dimen/margin_small" android:layout_marginStart="@dimen/margin_tiny"
                    tools:text="10" />
            </LinearLayout>

            <TextView android:id="@+id/tv_balance_status" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="@string/balance_status_initial"
                android:textSize="@dimen/text_size_tiny" android:textColor="@color/text_secondary"
                android:background="@drawable/bg_status" android:padding="@dimen/status_bar_padding"
                android:layout_marginBottom="@dimen/margin_small" android:gravity="center"
                tools:ignore="SmallSp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="@dimen/padding_card"
                android:baselineAligned="false">
                <Button android:id="@+id/btn_op_minus5" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/op_minus_5" android:textSize="@dimen/text_size_small"
                    style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="@dimen/margin_tiny"/>
                <Button android:id="@+id/btn_op_plus5"  android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/op_plus_5" android:textSize="@dimen/text_size_small"
                    style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="@dimen/margin_tiny"/>
                <Button android:id="@+id/btn_op_times2" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/op_times_2" android:textSize="@dimen/text_size_small"
                    style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="@dimen/margin_tiny"/>
                <Button android:id="@+id/btn_op_div2"   android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/op_div_2" android:textSize="@dimen/text_size_small"
                    style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="@dimen/margin_tiny"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/padding_card">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/x_equals" android:textSize="@dimen/text_size_body" android:fontFamily="monospace"
                    android:textColor="@color/text_primary" android:layout_marginEnd="@dimen/margin_small"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusBottomEnd="@dimen/margin_tiny" app:boxCornerRadiusTopEnd="@dimen/margin_tiny"
                    app:boxCornerRadiusBottomStart="@dimen/margin_tiny" app:boxCornerRadiusTopStart="@dimen/margin_tiny">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_answer"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" android:hint="@string/answer_hint"
                        android:textSize="@dimen/text_size_body" android:fontFamily="monospace" android:gravity="center"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_verify"
                    android:layout_width="wrap_content" android:layout_height="@dimen/button_height_small"
                    android:text="@string/btn_verify" android:textSize="@dimen/text_size_small"
                    app:cornerRadius="@dimen/margin_small"
                    android:backgroundTint="?attr/colorPrimary"
                    android:layout_marginStart="@dimen/margin_small"
                    tools:ignore="SmallSp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>