<?xml version="1.0" encoding="utf-8"?><LinearLayout    xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    android:layout_width="match_parent"    android:layout_height="match_parent"    android:orientation="vertical"    android:background="?attr/backgroundColor">    <com.google.android.material.bottomnavigation.BottomNavigationView        android:id="@+id/bottom_nav"        android:layout_width="match_parent"        android:layout_height="@dimen/nav_bar_height"        android:background="?attr/colorSurface"        app:menu="@menu/menu_bottom_nav"        app:labelVisibilityMode="labeled"        app:itemTextColor="@color/nav_item_color"        app:itemIconTint="@color/nav_item_color"        android:elevation="@dimen/card_elevation"/>    <LinearLayout        android:layout_width="match_parent"        android:layout_height="@dimen/button_height"        android:orientation="horizontal"        android:gravity="center_vertical"        android:paddingStart="@dimen/margin_default"        android:paddingEnd="@dimen/margin_default"        android:background="?attr/colorSurface"        android:elevation="2dp">        <TextView            android:layout_width="match_parent"            android:layout_height="wrap_content"            android:text="Módulos"            android:textSize="@dimen/text_size_body"            android:textStyle="bold"            android:textColor="@color/text_primary"/>    </LinearLayout>    <ScrollView        android:layout_width="match_parent"        android:layout_height="0dp"        android:layout_weight="1"        android:padding="@dimen/padding_card">        <LinearLayout            android:layout_width="match_parent"            android:layout_height="wrap_content"            android:orientation="vertical">            <com.google.android.material.card.MaterialCardView                android:id="@+id/card_mod1"                android:layout_width="match_parent"                android:layout_height="wrap_content"                app:cardCornerRadius="@dimen/card_corner_radius"                app:cardElevation="0dp"                app:strokeWidth="1dp"                app:strokeColor="?attr/colorOutline"                android:layout_marginBottom="@dimen/margin_small"                android:clickable="true"                android:focusable="true">                <LinearLayout                    android:layout_width="match_parent"                    android:layout_height="wrap_content"                    android:orientation="vertical"                    android:padding="@dimen/padding_card">                    <LinearLayout                        android:layout_width="match_parent"                        android:layout_height="wrap_content"                        android:orientation="horizontal"                        android:gravity="center_vertical">                        <LinearLayout                            android:layout_width="0dp"                            android:layout_height="wrap_content"                            android:layout_weight="1"                            android:orientation="vertical">                            <TextView                                android:layout_width="wrap_content"                                android:layout_height="wrap_content"                                android:text="Módulo 1: Introducción"                                android:textSize="@dimen/text_size_body"                                android:textStyle="bold"                                android:textColor="@color/text_primary"/>                            <TextView                                android:id="@+id/tv_mod1_sub"                                android:layout_width="wrap_content"                                android:layout_height="wrap_content"                                android:text="x+a=b · 3 métodos"                                android:textSize="@dimen/text_size_small"                                android:textColor="@color/text_secondary"                                android:layout_marginTop="2dp"/>                            <ProgressBar                                android:id="@+id/pb_mod1"                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"                                android:layout_width="match_parent"                                android:layout_height="@dimen/progress_bar_height"                                android:progress="0"                                android:progressDrawable="@drawable/progress_bar_purple"                                android:layout_marginTop="@dimen/margin_small"/>                        </LinearLayout>                        <com.google.android.material.chip.Chip                            android:id="@+id/tv_mod1_badge"                            android:layout_width="wrap_content"                            android:layout_height="wrap_content"                            android:text="0%"                            android:textSize="@dimen/text_size_small"                            app:chipBackgroundColor="@color/color_primary_alpha"                            android:textColor="@color/color_primary_dark"                            android:layout_marginStart="@dimen/margin_small"/>                    </LinearLayout>                </LinearLayout>            </com.google.android.material.card.MaterialCardView>            <LinearLayout                android:id="@+id/ll_mod1_actions"                android:layout_width="match_parent"                android:layout_height="wrap_content"                android:orientation="horizontal"                android:paddingStart="@dimen/margin_default"                android:paddingEnd="@dimen/margin_default"                android:paddingBottom="@dimen/margin_default"                android:visibility="gone">                <com.google.android.material.button.MaterialButton                    android:id="@+id/btn_info"                    style="@style/Widget.Material3.Button.OutlinedButton"                    android:layout_width="0dp"                    android:layout_weight="1"                    android:layout_height="@dimen/inlay_action_button_size"                    android:text="📖 Info"                    android:textSize="@dimen/text_size_small"                    app:cornerRadius="@dimen/margin_small"                    android:layout_marginEnd="4dp"/>                <com.google.android.material.button.MaterialButton                    android:id="@+id/btn_ejemplos"                    style="@style/Widget.Material3.Button.OutlinedButton"                    android:layout_width="0dp"                    android:layout_weight="1"                    android:layout_height="@dimen/inlay_action_button_size"                    android:text="💡 Ejemplos"                    android:textSize="@dimen/text_size_small"                    app:cornerRadius="@dimen/margin_small"                    android:layout_marginEnd="4dp"/>                <com.google.android.material.button.MaterialButton                    android:id="@+id/btn_ejercicios"                    android:layout_width="0dp"                    android:layout_weight="1"                    android:layout_height="@dimen/inlay_action_button_size"                    android:text="✏️ Ejercicios"                    android:textSize="@dimen/text_size_small"                    android:backgroundTint="@color/color_primary"                    app:cornerRadius="@dimen/margin_small"/>            </LinearLayout>            <com.google.android.material.card.MaterialCardView                android:id="@+id/card_mod2"                android:layout_width="match_parent"                android:layout_height="wrap_content"                app:cardCornerRadius="@dimen/card_corner_radius"                app:cardElevation="0dp"                app:strokeWidth="1dp"                app:strokeColor="?attr/colorOutline"                android:layout_marginBottom="@dimen/margin_small"                android:alpha="0.45">                <LinearLayout                    android:layout_width="match_parent"                    android:layout_height="wrap_content"                    android:orientation="horizontal"                    android:gravity="center_vertical"                    android:padding="@dimen/padding_card">                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"                        android:layout_weight="1" android:orientation="vertical">                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"                            android:text="Módulo 2: Coeficientes"                            android:textSize="@dimen/text_size_body"                            android:textStyle="bold" android:textColor="@color/text_primary"/>                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"                            android:text="ax+b=c · Balanza"                            android:textSize="@dimen/text_size_small"                            android:textColor="@color/text_secondary" android:layout_marginTop="2dp"/>                    </LinearLayout>                    <TextView                        android:id="@+id/tv_mod2_lock"                        android:layout_width="wrap_content"                        android:layout_height="wrap_content"                        android:text="🔒"                        android:textSize="16sp"                        android:layout_marginStart="@dimen/margin_small"/>                </LinearLayout>            </com.google.android.material.card.MaterialCardView>            <TextView                android:id="@+id/tv_mod1_note"                android:layout_width="match_parent"                android:layout_height="wrap_content"                android:text="💡 Completa el Módulo 1 para desbloquear"                android:textSize="@dimen/text_size_small"                android:textColor="#92400E"                android:background="@drawable/bg_warn_note"                android:padding="@dimen/margin_small"                android:layout_marginBottom="@dimen/margin_small"/>            <TextView                android:id="@+id/tv_mod1_done_note"                android:layout_width="match_parent"                android:layout_height="wrap_content"                android:text="🎉 ¡Módulo 1 superado! Sigue así."                android:textSize="@dimen/text_size_small"                android:textColor="#065F46"                android:background="@drawable/bg_chip_outlined"                android:padding="@dimen/margin_small"                android:layout_marginBottom="@dimen/margin_small"                android:visibility="gone"/>        </LinearLayout>    </ScrollView></LinearLayout>