<?xml version="1.0" encoding="utf-8"?>
<!-- activity_ejercicio_tiles.xml — Refactorizado sin Hardcode -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOOLBAR (Reutilizando el patrón estandarizado) -->
    <LinearLayout android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_small"
        android:paddingEnd="@dimen/margin_small"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/card_elevation">

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/btn_exit_text"
            android:textSize="@dimen/text_size_tiny"
            android:textColor="@color/color_primary"
            app:cornerRadius="@dimen/margin_small"
            tools:ignore="SmallSp"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/exercise_title_3"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <com.google.android.material.chip.Chip android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/timer_default"
            android:textSize="@dimen/text_size_tiny"
            android:fontFamily="monospace"
            app:chipBackgroundColor="@color/warn_chip_bg"
            android:textColor="@color/warn_chip_text"
            android:layout_marginEnd="@dimen/margin_tiny"
            tools:ignore="SmallSp"/>

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_hint"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/medal_icon_size"
            android:layout_height="@dimen/medal_icon_size"
            android:text="@string/btn_hint"
            android:textSize="@dimen/text_size_small"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"
            android:layout_marginEnd="@dimen/margin_tiny"/>

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/medal_icon_size"
            android:layout_height="@dimen/medal_icon_size"
            android:text="@string/btn_hamburger"
            android:textSize="@dimen/text_size_body"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"/>
    </LinearLayout>

    <!-- DRAWER (Mismo patrón que layouts anteriores) -->
    <LinearLayout
        android:id="@+id/drawer_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/toolbar_height"
        android:background="?attr/colorSurface"
        android:padding="@dimen/margin_small"
        android:elevation="@dimen/card_elevation"
        android:visibility="gone"
        android:gravity="center"
        android:baselineAligned="false">

        <!-- Botones omitidos por brevedad, usar el mismo patrón que Balanza/Clásico -->
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_marginTop="@dimen/toolbar_height"
        android:padding="@dimen/margin_default">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.chip.Chip android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/method_tiles"
                android:textSize="@dimen/text_size_tiny"
                app:chipBackgroundColor="@color/color_primary_alpha"
                android:textColor="@color/color_primary_dark"
                android:layout_marginBottom="@dimen/margin_small"
                tools:ignore="SmallSp"/>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/padding_card"
                app:cardElevation="0dp"
                android:layout_marginBottom="@dimen/padding_card">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:padding="@dimen/margin_default">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_solve"
                        android:textSize="@dimen/text_size_tiny"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/margin_tiny"
                        tools:ignore="SmallSp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/eq_tiles"
                        android:textSize="@dimen/text_size_h1"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/tiles_instruction"
                android:textSize="@dimen/text_size_tiny"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/margin_small"
                tools:ignore="SmallSp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_small"
                android:baselineAligned="false">

                <!-- Lado Izquierdo -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="@dimen/tile_container_height"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/margin_small"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/color_primary"
                    app:strokeWidth="@dimen/tile_stroke_width"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="@dimen/tile_container_padding">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/label_left"
                            android:textSize="@dimen/text_size_micro"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginBottom="@dimen/margin_tiny"
                            tools:ignore="SmallSp"/>
                        <LinearLayout android:id="@+id/ll_tiles_left"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:orientation="horizontal" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView android:layout_width="@dimen/equal_divider_width" android:layout_height="wrap_content"
                    android:text="@string/equal_sign"
                    android:textSize="@dimen/text_size_h2"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>

                <!-- Lado Derecho -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="@dimen/tile_container_height"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/margin_small"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/color_primary"
                    app:strokeWidth="@dimen/tile_stroke_width"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:padding="@dimen/tile_container_padding">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/label_right"
                            android:textSize="@dimen/text_size_micro"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginBottom="@dimen/margin_tiny"
                            tools:ignore="SmallSp"/>
                        <LinearLayout android:id="@+id/ll_tiles_right"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:orientation="horizontal" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView android:id="@+id/tv_tiles_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tiles_status_initial"
                android:textSize="@dimen/text_size_tiny"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_status"
                android:padding="@dimen/status_bar_padding"
                android:layout_marginBottom="@dimen/padding_card"
                android:gravity="center"
                tools:ignore="SmallSp"/>

            <!-- Campo de Respuesta Estandarizado -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/x_equals"
                    android:textSize="@dimen/text_size_body"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="@dimen/margin_small"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusBottomEnd="@dimen/margin_tiny"
                    app:boxCornerRadiusTopEnd="@dimen/margin_tiny"
                    app:boxCornerRadiusBottomStart="@dimen/margin_tiny"
                    app:boxCornerRadiusTopStart="@dimen/margin_tiny">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="@string/answer_hint"
                        android:textSize="@dimen/text_size_body"
                        android:fontFamily="monospace"
                        android:gravity="center"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton android:id="@+id/btn_verify"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_small"
                    android:text="@string/btn_verify"
                    android:textSize="@dimen/text_size_small"
                    android:backgroundTint="@color/color_primary"
                    app:cornerRadius="@dimen/margin_small"
                    android:layout_marginStart="@dimen/margin_small"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>