<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundColor"
    tools:context=".ui.ejercicios.FinEjerciciosActivity">

    <!-- Header Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_default"
        android:paddingEnd="@dimen/margin_default"
        android:background="?attr/colorSurface"
        android:elevation="2dp"
        tools:ignore="UnusedAttribute">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_module_completed"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>

    <!-- Contenido Central -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/margin_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="56sp"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_default"
            android:importantForAccessibility="no"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/msg_module_finished"
            android:textSize="@dimen/text_size_h2"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_large"/>

        <!-- Grid de Resultados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/margin_default"
            android:baselineAligned="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="@dimen/tile_container_height"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                android:layout_marginEnd="@dimen/margin_small"
                app:cardBackgroundColor="@color/color_bg_tonal_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_fin_ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/zero"
                        android:textSize="@dimen/text_size_h1"
                        android:textStyle="bold"
                        android:textColor="@color/color_primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_correct"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="@dimen/tile_container_height"
                android:layout_weight="1"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_bg_tonal_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_fin_fail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/zero"
                        android:textSize="@dimen/text_size_h1"
                        android:textStyle="bold"
                        android:textColor="@color/error"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_incorrect"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Puntos Obtenidos -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tv_fin_pts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0 puntos"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/warn_chip_bg"
            android:textColor="@color/warn_chip_text"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_small"
            tools:ignore="SpeakableTextPresentCheck" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/summary_methods"
            android:textSize="@dimen/text_size_small"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_large"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_go_temas"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_back_to_topics"
            android:textSize="@dimen/text_size_body"
            android:backgroundTint="@color/color_primary"
            app:cornerRadius="@dimen/margin_small"
            android:contentDescription="@string/desc_back_to_topics"/>
    </LinearLayout>
</LinearLayout>