<?xml version="1.0" encoding="utf-8"?>
<!-- activity_exercise.xml — Activity genérica refactorizada -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_medium"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/toolbar_elevation">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/btn_exit_text"
            android:textSize="@dimen/text_size_button_small"
            android:textColor="?attr/colorPrimary"
            app:cornerRadius="@dimen/margin_small"/>

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/qa_temas"
            android:textSize="@dimen/text_size_caption"
            android:textStyle="bold"
            android:textColor="?attr/colorTextPrimary"
            android:gravity="center"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_tiny"
            android:text="@string/timer_default"
            android:textSize="@dimen/text_size_button_small"
            android:fontFamily="monospace"
            app:chipBackgroundColor="?attr/colorWarnChipBg"
            android:textColor="?attr/colorWarnChipText"
            android:layout_marginEnd="@dimen/margin_tiny"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hint"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/toolbar_button_size"
            android:layout_height="@dimen/toolbar_button_size"
            android:text="@string/btn_hint"
            android:textSize="@dimen/text_size_caption"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"
            android:layout_marginEnd="@dimen/margin_tiny"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/toolbar_button_size"
            android:layout_height="@dimen/toolbar_button_size"
            android:text="@string/btn_hamburger"
            android:textSize="@dimen/text_size_body"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"/>
    </LinearLayout>

    <!-- DRAWER (Menú desplegable) -->
    <LinearLayout
        android:id="@+id/drawer_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/drawer_top_margin"
        android:background="?attr/colorSurface"
        android:padding="@dimen/margin_small"
        android:elevation="@dimen/drawer_elevation"
        android:visibility="gone"
        android:gravity="center"
        android:baselineAligned="false">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_inicio"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="@dimen/button_height"
            android:layout_weight="1" android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_inicio_short" android:textSize="@dimen/text_size_micro" android:padding="0dp"
            app:icon="@drawable/ic_home" app:iconGravity="top" app:iconTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_temas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="@dimen/button_height"
            android:layout_weight="1" android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_temas_short" android:textSize="@dimen/text_size_micro" android:padding="0dp"
            app:icon="@drawable/ic_book" app:iconGravity="top" app:iconTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_salas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="@dimen/button_height"
            android:layout_weight="1" android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_salas_short" android:textSize="@dimen/text_size_micro" android:padding="0dp"
            app:icon="@drawable/ic_room" app:iconGravity="top" app:iconTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_stats"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="@dimen/button_height"
            android:layout_weight="1" android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_stats_short" android:textSize="@dimen/text_size_micro" android:padding="0dp"
            app:icon="@drawable/ic_bar_chart" app:iconGravity="top" app:iconTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_config"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="@dimen/button_height"
            android:layout_weight="1" android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_config_short" android:textSize="@dimen/text_size_micro" android:padding="0dp"
            app:icon="@drawable/ic_settings" app:iconGravity="top"/>
    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/drawer_top_margin"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <FrameLayout
            android:id="@+id/panel_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Fila de respuesta común -->
        <LinearLayout
            android:id="@+id/container_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/margin_medium"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/x_equals"
                android:textSize="@dimen/text_size_subtitle"
                android:fontFamily="monospace"
                android:textColor="?attr/colorTextPrimary"
                android:layout_marginEnd="@dimen/margin_small"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius" app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius" app:boxCornerRadiusTopStart="@dimen/input_corner_radius">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_answer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:hint="@string/answer_hint"
                    android:textSize="@dimen/text_size_title"
                    android:fontFamily="monospace"
                    android:gravity="center"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_verify"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_small"
                android:text="@string/btn_verify"
                android:textSize="@dimen/text_size_label"
                app:cornerRadius="@dimen/input_corner_radius"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginStart="@dimen/margin_small"/>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/celebration_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        android:visibility="visible" />

    <!-- LOADING OVERLAY -->
    <FrameLayout
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/loading_overlay_scrim"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:layout_gravity="center"/>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>