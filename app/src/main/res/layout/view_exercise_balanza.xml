<?xml version="1.0" encoding="utf-8"?>
<!-- Panel BALANZA — inflado en ExerciseActivity cuando exercise.type = "BALANZA" -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ecuación -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="16dp">
                <TextView android:id="@+id/tv_eq_label" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Resuelve:"
                    android:textSize="11sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp"/>
                <!-- La ecuación se inyecta dinámicamente desde el ViewModel -->
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SVG Balanza -->
        <ImageView
            android:id="@+id/iv_balanza"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:src="@drawable/ic_balanza"
            android:contentDescription="Balanza"
            android:layout_marginBottom="4dp"/>

        <!-- Labels LHS / RHS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tv_lhs" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:fontFamily="monospace"
                android:textColor="@color/color_primary" android:gravity="center"
                android:background="@drawable/bg_chip_outlined"
                android:padding="8dp" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="=" android:textSize="18sp" android:textColor="@color/text_secondary"
                android:layout_marginHorizontal="6dp"/>
            <TextView android:id="@+id/tv_rhs" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:fontFamily="monospace"
                android:textColor="@color/color_primary" android:gravity="center"
                android:background="@drawable/bg_chip_outlined"
                android:padding="8dp" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Status -->
        <TextView android:id="@+id/tv_balance_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="@color/text_secondary"
            android:background="@drawable/bg_status" android:padding="8dp"
            android:layout_marginBottom="10dp" android:gravity="center"/>

        <!-- Botones de operación (generados dinámicamente desde DB) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Aplica la misma operación a ambos lados:"
            android:textSize="11sp" android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/ll_op_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"/>
            <!-- Los botones se añaden en ExerciseActivity.bindBalanzaPanel() -->

    </LinearLayout>
</ScrollView>
