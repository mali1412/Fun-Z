<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="?attr/colorSurface">

    <!-- BARRA SUPERIOR - Muy compacta para priorizar la balanza -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorBgTonalCard"
        android:layout_marginBottom="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center">
            <TextView
                android:id="@+id/tv_balanza_equation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:text="@string/eq_balanza" />
            <TextView
                android:id="@+id/tv_balance_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="?attr/colorTextSecondary"
                android:text="@string/balance_instruction" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ESCENA FÍSICA - OCUPA EL ESPACIO CENTRAL PRINCIPAL -->
    <FrameLayout
        android:id="@+id/confetti_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/iv_balanza_base"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_balanza_base"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:contentDescription="@string/desc_balanza" />

        <RelativeLayout
            android:id="@+id/rl_balanza_arm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- PLATILLO LHS -->
            <ImageView
                android:id="@+id/iv_balanza_arm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_balanza_arm" />

            <FrameLayout
                android:id="@+id/container_lhs"
                android:layout_width="@dimen/balanza_plate_size"
                android:layout_height="@dimen/balanza_plate_size"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="8dp"
                android:clipChildren="false"
                android:background="@drawable/bg_tiles_drop_zone">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_plato"
                    android:scaleType="centerInside" />
                <GridLayout
                    android:id="@+id/grid_lhs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="28dp"
                    android:columnCount="3" />
            </FrameLayout>

            <!-- PLATILLO RHS -->
            <FrameLayout
                android:id="@+id/container_rhs"
                android:layout_width="@dimen/balanza_plate_size"
                android:layout_height="@dimen/balanza_plate_size"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="8dp"
                android:clipChildren="false"
                android:background="@drawable/bg_tiles_drop_zone">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_plato"
                    android:scaleType="centerInside" />
                <GridLayout
                    android:id="@+id/grid_rhs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="28dp"
                    android:columnCount="3" />
            </FrameLayout>
        </RelativeLayout>
    </FrameLayout>

    <!-- PANEL DE PIEZAS (Único panel inferior ahora) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/bg_equation_box"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginEnd="12dp"
            android:layout_marginStart="8dp"/>

        <LinearLayout
            android:id="@+id/ll_balanza_source_tiles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="start|center_vertical" />

        <ImageView
            android:id="@+id/iv_trash_bin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_trash" />
    </LinearLayout>

</LinearLayout>
