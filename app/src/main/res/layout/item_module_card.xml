<?xml version="1.0" encoding="utf-8"?>
<!-- Tarjeta de módulo reutilizable — inflada dinámicamente en TemasActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="@dimen/margin_medium">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/material_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation_small">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="@dimen/padding_medium">

            <!-- Fila superior: nombre + badge -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_tiny">

                <TextView android:id="@+id/tv_mod_name"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="@dimen/text_size_small"
                    android:textStyle="bold" android:textColor="@color/text_primary"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_mod_badge"
                    android:layout_width="wrap_content" android:layout_height="@dimen/chip_small_height"
                    android:textSize="@dimen/text_size_caption"
                    app:chipBackgroundColor="@color/color_primary_alpha"
                    android:textColor="@color/color_primary_dark"/>
            </LinearLayout>

            <TextView android:id="@+id/tv_mod_sub"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_button_small" android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/margin_small"/>

            <ProgressBar android:id="@+id/pb_mod"
                android:layout_width="match_parent" android:layout_height="@dimen/tile_container_padding"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_marginBottom="@dimen/step_padding_vertical_active"
                android:progress="0"/>

            <!-- Botones de acción (List Inlay — visibilidad toggleada) -->
            <LinearLayout android:id="@+id/ll_mod_actions"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_info"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="@dimen/toolbar_button_size"
                    android:layout_weight="1" android:layout_margin="@dimen/chip_margin_end_small"
                    android:text="@string/module_card_btn_info" android:textSize="@dimen/text_size_button_small"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ejemplos"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="@dimen/toolbar_button_size"
                    android:layout_weight="1" android:layout_margin="@dimen/chip_margin_end_small"
                    android:text="@string/module_card_btn_examples" android:textSize="@dimen/text_size_button_small"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ejercicios"
                    android:layout_width="0dp" android:layout_height="@dimen/toolbar_button_size"
                    android:layout_weight="1" android:layout_margin="@dimen/chip_margin_end_small"
                    android:text="@string/module_card_btn_exercises" android:textSize="@dimen/text_size_button_small"
                    app:cornerRadius="@dimen/margin_small"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Overlay de bloqueo (alpha sobre la tarjeta) -->
        <FrameLayout android:id="@+id/view_lock_overlay"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="?attr/colorBgTonalCard" android:alpha="0.9" android:visibility="gone">
            <TextView android:id="@+id/tv_lock_msg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/module_card_locked_with_icon"
                android:textSize="@dimen/text_size_caption" android:textStyle="bold"
                android:textColor="@color/text_secondary"/>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
