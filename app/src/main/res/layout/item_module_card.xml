<?xml version="1.0" encoding="utf-8"?>
<!-- Tarjeta de módulo reutilizable — inflada dinámicamente en TemasActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/material_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Fila superior: nombre + badge -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView android:id="@+id/tv_mod_name"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_mod_badge"
                    android:layout_width="wrap_content" android:layout_height="26dp"
                    android:textSize="10sp"
                    app:chipBackgroundColor="@color/color_primary_alpha"
                    android:textColor="@color/color_primary_dark"/>
            </LinearLayout>

            <TextView android:id="@+id/tv_mod_sub"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"/>

            <ProgressBar android:id="@+id/pb_mod"
                android:layout_width="match_parent" android:layout_height="6dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_marginBottom="10dp"
                android:progress="0"/>

            <!-- Botones de acción (List Inlay — visibilidad toggleada) -->
            <LinearLayout android:id="@+id/ll_mod_actions"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_info"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:text="📖 Info" android:textSize="11sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ejemplos"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:text="💡 Ejemplos" android:textSize="11sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ejercicios"
                    android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:text="▶ Ejercicios" android:textSize="11sp"
                    app:cornerRadius="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Overlay de bloqueo (alpha sobre la tarjeta) -->
        <FrameLayout android:id="@+id/view_lock_overlay"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="?attr/colorBgTonalCard" android:alpha="0.9" android:visibility="gone">
            <TextView android:id="@+id/tv_lock_msg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🔒 Bloqueado"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"/>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
