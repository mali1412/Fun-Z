<?xml version="1.0" encoding="utf-8"?>
<!-- Panel CLÁSICO — inflado cuando exercise.type = "CLASICO" -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ecuación destacada -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_corner_radius_small" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorBgTonalCard"
            android:layout_marginBottom="@dimen/margin_default">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_default">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/label_solve" android:textSize="@dimen/text_size_button_small"
                    android:textColor="?attr/colorTextSecondary" android:layout_marginBottom="@dimen/margin_tiny"/>
                <TextView android:id="@+id/tv_equation_display"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_equation" android:textStyle="bold"
                    android:fontFamily="monospace" android:textColor="?attr/colorTextPrimary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Título de pasos -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/classic_steps_title"
            android:textSize="@dimen/text_size_label" android:textStyle="bold"
            android:textColor="?attr/colorTextPrimary"
            android:layout_marginBottom="@dimen/margin_small"/>

        <!-- Pasos de solución (generados dinámicamente desde JSON en DB) -->
        <LinearLayout
            android:id="@+id/ll_solution_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card"
            android:animateLayoutChanges="true"/>
            <!-- Los TextViews de cada paso se añaden en bindClasicoPanel() -->

    </LinearLayout>
</ScrollView>
