<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOOLBAR SUPERIOR -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_small"
        android:paddingEnd="@dimen/margin_small"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/toolbar_elevation">

        <TextView
            android:id="@+id/tv_module_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/module_title_placeholder"
            android:textSize="@dimen/text_size_caption"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/toolbar_button_size"
            android:layout_height="@dimen/toolbar_button_size"
            android:text="@string/btn_hamburger"
            android:textSize="@dimen/text_size_body"
            android:padding="0dp"
            app:cornerRadius="@dimen/margin_small"/>
    </LinearLayout>

    <!-- DRAWER -->
    <LinearLayout
        android:id="@+id/drawer_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/drawer_top_margin"
        android:background="?attr/colorSurface"
        android:padding="@dimen/margin_small"
        android:elevation="@dimen/drawer_elevation"
        android:visibility="gone"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_inicio"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_inicio_short"
            android:textSize="@dimen/text_size_micro"
            android:padding="0dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_temas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_temas_short"
            android:textSize="@dimen/text_size_micro"
            android:padding="0dp"
            app:icon="@drawable/ic_book"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_salas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_salas_short"
            android:textSize="@dimen/text_size_micro"
            android:padding="0dp"
            app:icon="@drawable/ic_room"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_stats"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_stats_short"
            android:textSize="@dimen/text_size_micro"
            android:padding="0dp"
            app:icon="@drawable/ic_bar_chart"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_config"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="@dimen/margin_xxsmall"
            android:text="@string/nav_config_short"
            android:textSize="@dimen/text_size_micro"
            android:padding="0dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="top" />

    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="@dimen/drawer_top_margin">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tab_layout_height"
            android:background="?attr/colorSurface"
            app:tabTextColor="?attr/colorTextSecondary"
            app:tabSelectedTextColor="?attr/colorPrimary"
            app:tabIndicatorColor="?attr/colorPrimary"
            app:tabIndicatorHeight="@dimen/tab_indicator_height"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_default">

                <LinearLayout
                    android:id="@+id/content_info"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/card_corner_radius_small"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryAlpha"
                        android:layout_marginBottom="@dimen/margin_medium">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="@dimen/padding_xlarge">
                            <TextView android:id="@+id/tv_info_title_1"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textStyle="bold" android:textSize="@dimen/text_size_title"
                                android:textColor="?attr/colorPrimary"
                                android:layout_marginBottom="@dimen/margin_small"/>
                            <TextView android:id="@+id/tv_info_text_1"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_small" android:textColor="?attr/colorPrimary"
                                android:lineSpacingExtra="@dimen/margin_tiny"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/card_corner_radius_small"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryAlpha"
                        android:layout_marginBottom="@dimen/margin_medium">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="@dimen/padding_xlarge">
                            <TextView android:id="@+id/tv_info_title_2"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textStyle="bold" android:textSize="@dimen/text_size_title"
                                android:textColor="?attr/colorPrimary"
                                android:layout_marginBottom="@dimen/margin_small"/>
                            <TextView android:id="@+id/tv_info_text_2"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_small" android:textColor="?attr/colorPrimary"
                                android:lineSpacingExtra="@dimen/margin_tiny"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/card_corner_radius_small"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryAlpha"
                        android:layout_marginBottom="@dimen/margin_medium">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="@dimen/padding_xlarge">
                            <TextView android:id="@+id/tv_info_title_3"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textStyle="bold" android:textSize="@dimen/text_size_title"
                                android:textColor="?attr/colorPrimary"
                                android:layout_marginBottom="@dimen/margin_small"/>
                            <TextView android:id="@+id/tv_info_text_3"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_small" android:textColor="?attr/colorPrimary"
                                android:lineSpacingExtra="@dimen/margin_tiny"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/content_ejemplos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/ll_examples_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- BARRA DE NAVEGACIÓN INFERIOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/margin_default"
            android:paddingEnd="@dimen/margin_default"
            android:background="?attr/colorSurface"
            android:elevation="@dimen/card_elevation">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_volver"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/btn_back_arrow"
                android:textSize="@dimen/text_size_small"
                app:cornerRadius="@dimen/margin_small"/>

            <TextView
                android:id="@+id/tv_page_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/page_indicator_default"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/btn_examples_next"
                android:textSize="@dimen/text_size_small"
                android:backgroundTint="@color/color_primary"
                app:cornerRadius="@dimen/margin_small"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
