<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOOLBAR SUPERIOR -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tv_module_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Módulo 1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="&#8801;"
            android:textSize="16sp"
            android:padding="0dp"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <!-- DRAWER -->
    <LinearLayout
        android:id="@+id/drawer_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="50dp"
        android:background="?attr/colorSurface"
        android:padding="@dimen/margin_small"
        android:elevation="8dp"
        android:visibility="gone"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_inicio"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Inicio"
            android:textSize="9sp"
            android:padding="0dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_temas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Temas"
            android:textSize="9sp"
            android:padding="0dp"
            app:icon="@drawable/ic_book"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_salas"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Salas"
            android:textSize="9sp"
            android:padding="0dp"
            app:icon="@drawable/ic_room"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_stats"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Stats"
            android:textSize="9sp"
            android:padding="0dp"
            app:icon="@drawable/ic_bar_chart"
            app:iconGravity="top"
            app:iconTint="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawer_config"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Config"
            android:textSize="9sp"
            android:padding="0dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="top" />

    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="50dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/colorSurface"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/color_primary"
            app:tabIndicatorColor="@color/color_primary"
            app:tabIndicatorHeight="2dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="@dimen/padding_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/content_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryAlpha"
                        android:layout_marginBottom="@dimen/margin_default">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="@dimen/padding_card">
                            <TextView android:id="@+id/tv_info_title_1"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="¿Qué es una ecuación?" android:textSize="@dimen/text_size_body"
                                android:textStyle="bold" android:textColor="?attr/colorPrimary"
                                android:layout_marginBottom="@dimen/margin_small"/>
                            <TextView android:id="@+id/tv_info_text_1"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="@dimen/text_size_small" android:textColor="?attr/colorPrimary"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorPrimaryAlpha"
                        android:layout_marginBottom="@dimen/margin_default">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="@dimen/padding_card">
                            <TextView android:id="@+id/tv_info_title_2"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Forma simple" android:textSize="@dimen/text_size_body"
                                android:textStyle="bold" android:textColor="?attr/colorPrimary"
                                android:layout_marginBottom="@dimen/margin_small"/>
                            <TextView android:id="@+id/tv_info_text_2"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="@dimen/text_size_small" android:textColor="?attr/colorPrimary"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/content_ejemplos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView android:id="@+id/tv_example_equation"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="x + 3 = 7"
                        android:fontFamily="monospace" android:textSize="@dimen/text_size_h1"
                        android:textColor="@color/text_primary" android:padding="@dimen/margin_default"
                        android:background="@drawable/bg_equation_box"
                        android:gravity="center" android:layout_marginBottom="@dimen/margin_default"/>

                    <LinearLayout android:id="@+id/ll_example_steps"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- BARRA DE NAVEGACIÓN INFERIOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/margin_default"
            android:paddingEnd="@dimen/margin_default"
            android:background="?attr/colorSurface"
            android:elevation="@dimen/card_elevation">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_volver"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="← Volver"
                android:textSize="@dimen/text_size_small"
                app:cornerRadius="@dimen/margin_small"/>

            <TextView
                android:id="@+id/tv_page_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 / 2"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="Ejemplos →"
                android:textSize="@dimen/text_size_small"
                android:backgroundTint="@color/color_primary"
                app:cornerRadius="@dimen/margin_small"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
