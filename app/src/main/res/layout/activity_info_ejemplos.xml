<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_info_ejemplos.xml — Pantalla C: Información / Ejemplos
    Topbar: ← Temas | Módulo 1 | ≡ (hamburguesa)
    TabLayout: Información | Ejemplos
    Contenido conmutable + NavFooter con botón siguiente
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- TOPBAR con hamburguesa -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="← Temas"
            android:textSize="11sp"
            android:textColor="@color/color_primary"
            app:cornerRadius="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Módulo 1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hamburger"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="≡"
            android:textSize="16sp"
            android:padding="0dp"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <!-- DRAWER MENÚ HAMBURGUESA -->
    <LinearLayout
        android:id="@+id/drawer_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="50dp"
        android:background="?attr/colorSurface"
        android:padding="8dp"
        android:elevation="8dp"
        android:visibility="gone">

        <Button android:id="@+id/drawer_inicio" android:layout_width="wrap_content" android:layout_height="34dp" android:text="🏠 Inicio" android:textSize="11sp" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="3dp"/>
        <Button android:id="@+id/drawer_temas"  android:layout_width="wrap_content" android:layout_height="34dp" android:text="📚 Temas"  android:textSize="11sp" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="3dp"/>
        <Button android:id="@+id/drawer_salas"  android:layout_width="wrap_content" android:layout_height="34dp" android:text="🏟 Salas"  android:textSize="11sp" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="3dp"/>
        <Button android:id="@+id/drawer_stats"  android:layout_width="wrap_content" android:layout_height="34dp" android:text="📊 Stats"  android:textSize="11sp" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="3dp"/>
        <Button android:id="@+id/drawer_config" android:layout_width="wrap_content" android:layout_height="34dp" android:text="⚙️ Config" android:textSize="11sp" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_margin="3dp"/>
    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="50dp">

        <!-- TABS -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="?attr/colorSurface"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/color_primary"
            app:tabIndicatorColor="@color/color_primary"
            app:tabIndicatorHeight="2dp"/>

        <!-- SCROLL AREA -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CONTENIDO INFORMACIÓN -->
                <LinearLayout
                    android:id="@+id/content_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/color_primary_alpha"
                        app:strokeColor="@color/color_primary_light"
                        app:strokeWidth="0.5dp"
                        android:layout_marginBottom="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="13dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="¿Qué es una ecuación?" android:textSize="13sp"
                                android:textStyle="bold" android:textColor="@color/color_primary_dark"
                                android:layout_marginBottom="5dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Una igualdad matemática con una o más incógnitas. El objetivo es encontrar el valor de x que hace verdadera la igualdad."
                                android:textSize="12sp" android:textColor="@color/color_primary_dark"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/color_primary_alpha"
                        app:strokeColor="@color/color_primary_light"
                        app:strokeWidth="0.5dp"
                        android:layout_marginBottom="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="13dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Forma simple: x + a = b" android:textSize="13sp"
                                android:textStyle="bold" android:textColor="@color/color_primary_dark"
                                android:layout_marginBottom="5dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Solo se necesita sumar o restar en ambos lados para despejar x. El principio clave: lo que haces a un lado, debes hacerlo al otro."
                                android:textSize="12sp" android:textColor="@color/color_primary_dark"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Video placeholder -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📹 Video explicativo" android:textSize="11sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="6dp"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="80dp"
                                android:background="#1A1A2E">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:text="▶" android:textSize="26sp"
                                    android:textColor="#FFFFFF"/>
                            </FrameLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- CONTENIDO EJEMPLOS -->
                <LinearLayout
                    android:id="@+id/content_ejemplos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Procedimiento de resolución:" android:textSize="12sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="10dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="x + 3 = 7"
                        android:fontFamily="monospace" android:textSize="16sp"
                        android:textColor="@color/text_primary" android:padding="10dp"
                        android:background="@drawable/bg_equation_box"
                        android:gravity="center" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="22dp" android:layout_height="22dp"
                            android:text="1" android:textSize="10sp" android:textColor="#FFFFFF"
                            android:gravity="center" android:background="@drawable/bg_step_circle"
                            android:layout_marginEnd="10dp" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Identificar el término a eliminar del lado izquierdo: +3"
                            android:textSize="12sp" android:textColor="@color/text_primary"
                            android:lineSpacingExtra="3dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="22dp" android:layout_height="22dp"
                            android:text="2" android:textSize="10sp" android:textColor="#FFFFFF"
                            android:gravity="center" android:background="@drawable/bg_step_circle"
                            android:layout_marginEnd="10dp" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Aplicar operación inversa en ambos lados: x + 3 − 3 = 7 − 3"
                            android:textSize="12sp" android:textColor="@color/text_primary"
                            android:lineSpacingExtra="3dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="22dp" android:layout_height="22dp"
                            android:text="3" android:textSize="10sp" android:textColor="#FFFFFF"
                            android:gravity="center" android:background="@drawable/bg_step_circle"
                            android:layout_marginEnd="10dp" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Simplificar: x = 4 ✓"
                            android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/color_primary" android:lineSpacingExtra="3dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- NAV FOOTER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="?attr/colorSurface"
            android:elevation="4dp">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="← Volver"
                android:textSize="12sp"
                android:onClick="onBackPressed"
                app:cornerRadius="8dp"/>

            <TextView
                android:id="@+id/tv_page_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 / 2"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Ejemplos →"
                android:textSize="12sp"
                android:backgroundTint="@color/color_primary"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
