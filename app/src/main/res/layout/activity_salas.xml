<?xml version="1.0" encoding="utf-8"?>
<!-- activity_salas.xml — Pantalla E: Salas (próxima versión) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundColor">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:menu="@menu/menu_bottom_nav"
        app:labelVisibilityMode="labeled"
        app:itemTextColor="@color/nav_item_color"
        app:itemIconTint="@color/nav_item_color"
        android:elevation="@dimen/card_elevation"/>

    <!-- Título de la pantalla -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_default"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/card_elevation_small">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_salas"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>
    </LinearLayout>

    <!-- Contenido Central -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ic_rocket"
            android:textSize="@dimen/text_size_emoji_large"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_default"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/coming_soon"
            android:textSize="@dimen/text_size_h2"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/salas_coming_soon_desc"
            android:textSize="@dimen/text_size_caption"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/margin_tiny"/>
    </LinearLayout>
</LinearLayout>