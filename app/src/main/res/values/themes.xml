<?xml version="1.0" encoding="utf-8"?>
<!--
    res/values/themes.xml — Tema claro (default) + Tema oscuro
-->
<resources>
    <!-- Tema claro -->
    <style name="Theme.FunZ" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_primary_dark</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="backgroundColor">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/color_primary</item>
        <item name="android:navigationBarColor">@color/surface_light</item>

        <item name="colorTextPrimary">@color/text_primary</item>
        <item name="colorTextSecondary">@color/text_secondary</item>
        <item name="colorBgTonalCard">@color/color_bg_tonal_card</item>
        <item name="colorNavItem">@color/text_secondary</item>
        <item name="colorWarnChipBg">@color/warn_chip_bg</item>
        <item name="colorWarnChipText">@color/warn_chip_text</item>
        <item name="colorPrimaryAlpha">@color/color_primary_alpha</item>

    </style>



    <!-- Tema oscuro -->
    <style name="Theme.FunZ.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/color_primary_light</item>
        <item name="colorPrimaryDark">@color/color_primary</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="backgroundColor">@color/background_dark</item>
        <item name="android:textColorPrimary">#F9FAFB</item>
        <item name="android:textColorSecondary">#9CA3AF</item>
        <item name="android:statusBarColor">@color/color_primary_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>


        <item name="colorTextPrimary">#F9FAFB</item>
        <item name="colorTextSecondary">#9CA3AF</item>
        <item name="colorBgTonalCard">@color/card_dark</item>
        <item name="colorNavItem">#F9FAFB</item>
        <item name="colorWarnChipBg">#451A03</item> <item name="colorWarnChipText">#FDE68A</item> <item name="colorPrimaryAlpha">#33E1BEE7</item> </style>

</resources>
